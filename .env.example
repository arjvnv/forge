# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (used only for text-embedding-3-small routing vectors)
OPENAI_API_KEY=sk-...

# Redis
REDIS_URL=redis://localhost:6379

# Postgres
POSTGRES_USER=forge
POSTGRES_PASSWORD=forge
POSTGRES_DB=forge
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://forge:forge@localhost:5432/forge

# Arize
ARIZE_API_KEY=...
ARIZE_SPACE_KEY=...
ARIZE_PROJECT_NAME=forge-eval

# App
FORGE_ENV=development
FORGE_EMBED_MODEL=text-embedding-3-small
FORGE_SYNTH_MODEL=claude-opus-4-8
FORGE_ROUTE_MODEL=claude-sonnet-4-6
SIMILARITY_THRESHOLD=0.85

# Eval
EVAL_MEASUREMENT_YEAR=2023
EVAL_K_RUNS=5
EVAL_N_CYCLES=6
